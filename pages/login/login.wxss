.login-page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: linear-gradient(180deg, #fff8ee 0%, #f7fbf7 100%);
  box-sizing: border-box;
}

.login-card {
  margin-top: 120rpx;
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 56rpx 40rpx;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.login-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-bottom: 28rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2937;
}

.login-desc {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #6b7280;
}

.login-btn {
  width: 100%;
  margin-top: 48rpx;
  background-color: #16a34a;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 92rpx;
}

.login-btn::after {
  border: none;
}

.login-status {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.7;
}
