/* pages/feedback/feedback.wxss */
.container {
  background-color: #f8f9fa;
  min-height: 100vh;
  width: 100%;
}

.header-bar {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.form-card {
  margin: 20rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.form-item {
  margin-bottom: 24rpx;
}
.label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}
.input {
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
}
.textarea {
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  min-height: 200rpx;
}

.submit-btn {
  margin-top: 10rpx;
  background-color: #3cc51f;
  border-radius: 30rpx;
  padding: 20rpx;
  text-align: center;
}
.btn-text {
  font-size: 28rpx;
  color: #fff;
}

.success-tip {
  margin: 20rpx;
  padding: 24rpx;
  background-color: #f0fff0;
  border: 1rpx solid #c8f7c5;
  border-radius: 12rpx;
}
.tip-text {
  font-size: 26rpx;
  color: #2f8f2f;
}