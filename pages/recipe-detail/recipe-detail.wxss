/* pages/recipe-detail/recipe-detail.wxss */
.container {
  background-color: #f8f9fa;
  display: block !important;
  height: auto !important;
  min-height: 100vh;
  /* 单独使用容器底部预留，避免与占位层叠加造成过多空白 */
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom)) !important;
}

/* 主图区域 */
.hero-section {
  position: relative;
  width: 100%;
  height: 500rpx;
  /* 防止被父级 .container 的 flex 布局压缩导致高度变小 */
  flex-shrink: 0;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.8));
  padding: 40rpx 30rpx 30rpx;
  color: #fff;
}

.recipe-info {
  display: flex;
  flex-direction: column;
}

.recipe-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #fff;
}

.recipe-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.meta-item {
  font-size: 24rpx;
  background-color: rgba(255,255,255,0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  color: #fff;
}

.recipe-description {
  font-size: 28rpx;
  line-height: 1.6;
  color: #fff;
  opacity: 0.9;
}

/* 基本信息 */
.info-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.author-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.author-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.author-details {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.author-desc {
  font-size: 24rpx;
  color: #999;
}

.nutrition-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #f8f9fa;
  border-radius: 10rpx;
}

.nutrition-label {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.nutrition-value {
  font-size: 24rpx;
  font-weight: bold;
  color: #3cc51f;
}

/* 所需材料 */
.ingredients-section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
}

.ingredients-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ingredient-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 15rpx;
  border-left: 4rpx solid #3cc51f;
}

.ingredient-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.ingredient-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.ingredient-amount {
  font-size: 24rpx;
  color: #666;
}

.ingredient-checkbox {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ddd;
  border-radius: 50%;
}

.checkbox-icon {
  font-size: 20rpx;
  color: #999;
}

/* 制作步骤 */
.steps-section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.steps-list {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.step-item {
  display: flex;
  gap: 20rpx;
}

.step-number {
  width: 60rpx;
  height: 60rpx;
  background-color: #3cc51f;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.step-header {
  margin-bottom: 15rpx;
}

.step-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.step-tips {
  font-size: 24rpx;
  color: #ff6b6b;
  background-color: #fff5f5;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.step-description {
  font-size: 28rpx;
  line-height: 1.6;
  color: #666;
  margin-bottom: 20rpx;
}

.step-image {
  width: 100%;
  height: 300rpx;
  border-radius: 15rpx;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  /* 为 iOS 安全区留白 */
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  gap: 20rpx;
  z-index: 100;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-radius: 15rpx;
  min-width: 120rpx;
  transition: all 0.3s ease;
}

.favorite-btn {
  background-color: #f8f9fa;
  color: #666;
}

.favorite-btn.favorited {
  background-color: #ff6b6b;
  color: #fff;
}

.share-btn {
  background-color: #f8f9fa;
  color: #666;
}

.cook-btn {
  flex: 1;
  background-color: #3cc51f;
  color: #fff;
  font-weight: bold;
}

.action-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
}

/* 分享弹窗 */
.share-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.share-modal.show {
  opacity: 1;
  visibility: visible;
}

.share-content {
  background-color: #fff;
  width: 100%;
  border-radius: 30rpx 30rpx 0 0;
  padding: 40rpx 30rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.share-modal.show .share-content {
  transform: translateY(0);
}

.share-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.share-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.share-close {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

.share-options {
  display: flex;
  gap: 40rpx;
  justify-content: center;
}

.share-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  min-width: 120rpx;
}

.share-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.share-label {
  font-size: 24rpx;
  color: #333;
}

/* 取消占位层高度，避免重复预留导致底部出现大面积空白 */
.bottom-spacer {
  height: 0;
  display: none;
}
