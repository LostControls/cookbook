<view class="page">
  <view class="hero">
    <view class="hero-top">
      <view class="brand-copy">
        <text class="hero-label">{{brandName}}</text>
        <text class="hero-title">{{greeting}}</text>
        <text class="hero-slogan">{{brandSlogan}}</text>
      </view>
      <view class="hero-action" bindtap="onQuickActionTap">{{quickActionText}}</view>
    </view>

    <view class="brand-panel">
      <image class="brand-logo" src="{{heroPanel.logo}}" mode="aspectFit" />
      <view class="brand-panel-copy">
        <text class="brand-panel-title">{{heroPanel.title}}</text>
        <text class="brand-panel-desc">{{heroPanel.desc}}</text>
      </view>
    </view>

    <view class="search-shell">
      <input
        class="search-input"
        placeholder="搜索菜谱、食材或做法"
        value="{{searchValue}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <view class="search-button" bindtap="onSearch">搜索</view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">常用分类</text>
      <text class="section-desc">更快找到今天想做的菜。</text>
    </view>
    <view class="category-grid">
      <view
        class="category-item"
        wx:for="{{categoryList}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
        bindtap="onCategoryTap"
        style="background: {{item.color}}"
      >
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">本周专题</text>
      <text class="section-desc">先用简洁内容完成体验，后续再接后台维护。</text>
    </view>
    <view class="topic-list">
      <view
        class="topic-card"
        wx:for="{{topicList}}"
        wx:key="id"
        data-title="{{item.title}}"
        bindtap="onTopicTap"
      >
        <text class="topic-tag">{{item.tag}}</text>
        <text class="topic-title">{{item.title}}</text>
        <text class="topic-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">推荐菜谱</text>
      <text class="section-desc">当前已接真实菜谱数据，会按热度推荐。</text>
    </view>
    <view class="recipe-list">
      <view
        class="recipe-card"
        wx:for="{{recommendRecipes}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-index="{{index}}"
        bindtap="onRecipeTap"
      >
        <image class="recipe-cover" src="{{item.image}}" mode="aspectFill" />
        <view class="recipe-content">
          <view class="recipe-main">
            <text class="recipe-title">{{item.title}}</text>
            <text class="recipe-desc">{{item.desc}}</text>
          </view>
          <view class="recipe-footer">
            <view class="recipe-meta">
              <text class="recipe-pill">{{item.difficulty}}</text>
              <text class="recipe-pill">{{item.time}}</text>
            </view>
            <view
              class="favorite-toggle {{item.isFavorite ? 'favorite-toggle--active' : ''}}"
              data-id="{{item.id}}"
              data-index="{{index}}"
              catchtap="onFavoriteTap"
            >
              {{item.isFavorite ? '已收藏' : '收藏'}}
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section section--compact">
    <view class="section-head">
      <text class="section-title">灵感清单</text>
      <text class="section-desc">适合后续继续补充个性化推荐和常做菜单。</text>
    </view>
    <view class="mini-list">
      <view class="mini-item" wx:for="{{recentMenu}}" wx:key="id">
        <text class="mini-title">{{item.title}}</text>
        <text class="mini-desc">{{item.note}}</text>
      </view>
    </view>
  </view>
</view>
