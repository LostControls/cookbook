<view class="page">
  <view class="header-bar">
    <text class="title">我的收藏</text>
    <view class="clear-btn" bindtap="onClearAll" wx:if="{{!isEmpty}}">
      <text class="clear-text">清空</text>
    </view>
  </view>

  <view class="empty-state" wx:if="{{isEmpty}}">
    <view class="empty-icon">藏</view>
    <text class="empty-text">还没有收藏任何菜谱</text>
    <text class="empty-desc">去首页看看有什么想吃的，再把喜欢的菜留下来。</text>
    <view class="go-home-btn" bindtap="goToHome">
      <text class="btn-text">去首页</text>
    </view>
  </view>

  <view class="recipe-grid" wx:else>
    <view
      class="grid-item"
      wx:for="{{favoriteRecipes}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onRecipeTap"
    >
      <view
        class="remove-chip"
        data-id="{{item.id}}"
        data-index="{{index}}"
        catchtap="onRemoveFavorite"
      >
        ×
      </view>
      <image class="grid-image" src="{{item.image}}" mode="aspectFill" />
      <text class="grid-title">{{item.title}}</text>
    </view>
  </view>

  <view class="loading-state" wx:if="{{!isEmpty}}">
    <text class="loading-text">{{loading ? '加载中...' : (hasMore ? '上拉加载更多' : '没有更多了')}}</text>
  </view>
</view>
