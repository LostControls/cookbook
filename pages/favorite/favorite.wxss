.page {
  min-height: 100vh;
  padding: 0 0 30rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(255, 140, 72, 0.12), transparent 28%),
    linear-gradient(180deg, #fff9f4 0%, #f6f7fb 100%);
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx 20rpx;
  box-sizing: border-box;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #20262e;
}

.clear-btn {
  padding: 10rpx 22rpx;
  background: #ff7a7a;
  border-radius: 999rpx;
}

.clear-text {
  font-size: 24rpx;
  color: #ffffff;
}

.empty-state {
  margin-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  text-align: center;
}

.empty-icon {
  width: 116rpx;
  height: 116rpx;
  border-radius: 32rpx;
  background: #fff1e6;
  color: #ff7a1a;
  font-size: 50rpx;
  line-height: 116rpx;
}

.empty-text {
  margin-top: 26rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #20262e;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a93a2;
}

.go-home-btn {
  margin-top: 34rpx;
  padding: 18rpx 42rpx;
  background: #ff7a1a;
  border-radius: 999rpx;
}

.btn-text {
  font-size: 28rpx;
  color: #ffffff;
}

.recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 8rpx 20rpx 20rpx;
  box-sizing: border-box;
}

.grid-item {
  position: relative;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.06);
}

.grid-item:active {
  transform: scale(0.99);
}

.remove-chip {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  z-index: 2;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(32, 38, 46, 0.72);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 44rpx;
  text-align: center;
}

.grid-image {
  width: 100%;
  height: 220rpx;
  background: #f3f5f8;
}

.grid-title {
  font-size: 28rpx;
  color: #20262e;
  padding: 16rpx;
}

.loading-state {
  padding-top: 8rpx;
  text-align: center;
}

.loading-text {
  font-size: 24rpx;
  color: #9ca5b3;
}
