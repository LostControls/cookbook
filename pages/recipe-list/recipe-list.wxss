.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(255, 140, 72, 0.12), transparent 28%),
    linear-gradient(180deg, #fff9f4 0%, #f6f7fb 100%);
}

.search-card {
  padding: 24rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.05);
}

.search-shell {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx 12rpx 12rpx 22rpx;
  border-radius: 999rpx;
  background: #f7f8fa;
}

.search-input {
  flex: 1;
  height: 64rpx;
  font-size: 28rpx;
  color: #20262e;
}

.search-btn {
  min-width: 112rpx;
  text-align: center;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: #ff7a1a;
  color: #ffffff;
  font-size: 26rpx;
}

.category-head {
  margin-top: 24rpx;
}

.category-copy {
  display: flex;
  flex-direction: column;
}

.category-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #20262e;
}

.category-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a93a2;
}

.recipe-list {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.recipe-card {
  position: relative;
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.05);
}

.recipe-card:active {
  transform: scale(0.995);
}

.recipe-cover {
  width: 176rpx;
  height: 176rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.recipe-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 100rpx;
}

.recipe-main {
  display: flex;
  flex-direction: column;
}

.recipe-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #20262e;
}

.recipe-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7f8897;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.recipe-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.meta-pill {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #697385;
  font-size: 22rpx;
}

.meta-author {
  font-size: 22rpx;
  color: #a0a8b5;
}

.favorite-btn {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  min-width: 86rpx;
  line-height: 48rpx;
  padding: 0 14rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #fff1e6;
  color: #ff7a1a;
  font-size: 22rpx;
}

.favorite-btn--active {
  background: #ff7a1a;
  color: #ffffff;
}

.empty-state {
  margin-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 0 48rpx;
}

.empty-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  background: #fff1e6;
  color: #ff7a1a;
  font-size: 48rpx;
  line-height: 112rpx;
  text-align: center;
}

.empty-title {
  margin-top: 26rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #20262e;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a93a2;
}

.loading-state {
  padding: 28rpx 0 10rpx;
  text-align: center;
}

.loading-text {
  font-size: 24rpx;
  color: #9ca5b3;
}
