<view class="page">
  <view class="search-card">
    <view class="search-shell">
      <input
        class="search-input"
        placeholder="搜索当前分类下的菜谱"
        value="{{searchValue}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <view class="search-btn" bindtap="onSearch">搜索</view>
    </view>

    <view class="category-head">
      <view class="category-copy">
        <text class="category-title">{{categoryName || '分类菜谱'}}</text>
        <text class="category-subtitle">共 {{total || recipes.length}} 道菜谱</text>
      </view>
    </view>
  </view>

  <view class="recipe-list" wx:if="{{recipes.length > 0}}">
    <view
      class="recipe-card"
      wx:for="{{recipes}}"
      wx:key="id"
      data-id="{{item.id}}"
      data-index="{{index}}"
      bindtap="onRecipeTap"
    >
      <image class="recipe-cover" src="{{item.image}}" mode="aspectFill" />

      <view class="recipe-body">
        <view class="recipe-main">
          <text class="recipe-title">{{item.title}}</text>
          <text class="recipe-desc">{{item.desc}}</text>
        </view>

        <view class="recipe-meta">
          <text class="meta-pill">{{item.difficulty}}</text>
          <text class="meta-pill">{{item.time}}</text>
          <text class="meta-author">{{item.author}}</text>
        </view>
      </view>

      <view
        class="favorite-btn {{item.isFavorite ? 'favorite-btn--active' : ''}}"
        data-id="{{item.id}}"
        data-index="{{index}}"
        catchtap="onFavoriteTap"
      >
        {{item.isFavorite ? '已藏' : '收藏'}}
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{initialized && recipes.length === 0 && !loading}}">
    <text class="empty-icon">食</text>
    <text class="empty-title">这个分类暂时还没有菜谱</text>
    <text class="empty-desc">换个分类看看，或者试试搜索其他关键词。</text>
  </view>

  <view class="loading-state" wx:if="{{loading || recipes.length > 0}}">
    <text class="loading-text">{{loading ? loadingText : (hasMore ? '上拉加载更多' : '没有更多了')}}</text>
  </view>
</view>
