<!-- pages/recipe-list/recipe-list.wxml -->
<view class="container">
  <!-- 头部：分类与搜索 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <input class="search-input" placeholder="搜索本分类菜谱" value="{{searchValue}}" bindinput="onSearchInput" />
      <view class="search-btn" bindtap="onSearch">
        <text class="search-icon">🔍</text>
      </view>
    </view>
    <view class="category-title">
      <text class="category-name">{{categoryName}}</text>
      <text class="category-count">共 {{recipes.length}} 道菜</text>
    </view>
  </view>

  <!-- 列表 -->
  <view class="recipe-list">
    <view 
      class="recipe-item" 
      wx:for="{{recipes}}" 
      wx:key="id"
      data-id="{{item.id}}"
      data-index="{{index}}"
      bindtap="onRecipeTap"
    >
      <image class="recipe-image" src="{{item.image}}" mode="aspectFill" />
      <view class="recipe-info">
        <text class="recipe-title">{{item.title}}</text>
        <view class="recipe-meta">
          <text class="meta-item">{{item.difficulty}}</text>
          <text class="meta-item">{{item.time}}</text>
          <text class="meta-item">⭐ {{item.rating}}</text>
        </view>
        <text class="recipe-author">by {{item.author}}</text>
      </view>
      <view 
        class="favorite-btn" 
        data-id="{{item.id}}"
        data-index="{{index}}"
        catchtap="onFavoriteTap"
      >
        <text class="favorite-icon">⭐</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{recipes.length === 0}}">
    <view class="empty-icon">🍽️</view>
    <text class="empty-text">该分类暂无菜谱</text>
    <text class="empty-desc">换个分类或试试搜索吧</text>
  </view>
</view>