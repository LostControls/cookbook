.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(255, 140, 72, 0.22), transparent 30%),
    linear-gradient(180deg, #fff9f4 0%, #f5f7fa 100%);
}

.hero-card {
  padding: 28rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 46rpx rgba(15, 23, 42, 0.06);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.hero-badge {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff2e8;
  color: #ff7a1a;
  font-size: 22rpx;
}

.brand-strip {
  margin-top: 26rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fff8f2 0%, #fff2e8 100%);
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-logo {
  width: 116rpx;
  height: 116rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.brand-strip-copy {
  flex: 1;
}

.brand-strip-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #20262e;
}

.brand-strip-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7d8796;
}

.profile-main {
  margin-top: 28rpx;
  padding: 10rpx 4rpx 0;
  display: flex;
  align-items: center;
}

.avatar-shell {
  width: 136rpx;
  height: 136rpx;
  padding: 8rpx;
  box-sizing: border-box;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff4ea 0%, #ffffff 100%);
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.08);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.profile-info {
  flex: 1;
  margin-left: 22rpx;
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 38rpx;
  font-weight: 600;
  color: #20262e;
}

.profile-badge {
  margin-top: 12rpx;
  display: inline-flex;
  align-self: flex-start;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fff1e6;
  color: #ff7a1a;
  font-size: 22rpx;
}

.profile-location {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #8993a3;
  min-height: 34rpx;
}

.profile-arrow {
  font-size: 30rpx;
  color: #c5ced8;
  margin-left: 12rpx;
}

.profile-tip {
  margin-top: 26rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: #fbf6ee;
}

.profile-tip-text {
  font-size: 24rpx;
  line-height: 1.8;
  color: #8c6330;
}

.stats-card {
  margin-top: 22rpx;
  padding: 28rpx 20rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.05);
  display: flex;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: 600;
  color: #20262e;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7e8897;
}

.stat-divider {
  width: 1rpx;
  background: #edf0f3;
  margin: 0 16rpx;
}

.section-head {
  margin: 28rpx 6rpx 16rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #20262e;
}

.section-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a93a2;
}

.menu-list {
  border-radius: 28rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f1f3f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8f9fb;
}

.menu-icon-wrap {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: #fff4ea;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
}

.menu-icon {
  font-size: 32rpx;
  color: #ff7a1a;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 30rpx;
  color: #20262e;
}

.menu-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #929dad;
}

.menu-arrow {
  font-size: 30rpx;
  color: #c5ced8;
}
