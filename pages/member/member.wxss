.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(255, 140, 72, 0.22), transparent 30%),
    linear-gradient(180deg, #fff9f4 0%, #f6f7fb 100%);
}

.hero-card {
  padding: 28rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 46rpx rgba(15, 23, 42, 0.06);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.hero-badge {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff2e8;
  color: #ff7a1a;
  font-size: 22rpx;
}

.brand-strip {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fff8f2 0%, #fff1e6 100%);
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-logo {
  width: 108rpx;
  height: 108rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

.brand-strip-copy {
  flex: 1;
}

.brand-strip-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #20262e;
}

.brand-strip-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7d8796;
}

.profile-main {
  margin-top: 26rpx;
  padding: 10rpx 4rpx 6rpx;
  display: flex;
  align-items: center;
}

.avatar-shell {
  width: 136rpx;
  height: 136rpx;
  padding: 8rpx;
  box-sizing: border-box;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff4ea 0%, #ffffff 100%);
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.08);
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.profile-info {
  flex: 1;
  margin-left: 22rpx;
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #20262e;
}

.profile-badge {
  margin-top: 10rpx;
  display: inline-flex;
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff1e6;
  color: #ff7a1a;
  font-size: 22rpx;
}

.profile-location {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #8993a3;
}

.profile-arrow {
  font-size: 30rpx;
  color: #c5ced8;
  margin-left: 12rpx;
}

.section-head {
  margin: 28rpx 6rpx 18rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #20262e;
}

.service-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.service-card {
  position: relative;
  padding: 24rpx 16rpx 22rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.service-card:active {
  transform: scale(0.98);
}

.service-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: #fff4ea;
  display: flex;
  align-items: center;
  justify-content: center;
}

.service-icon {
  font-size: 34rpx;
  color: #ff7a1a;
}

.service-title {
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #20262e;
}

.service-value {
  margin-top: 10rpx;
  min-width: 42rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #fff1e6;
  color: #ff7a1a;
  font-size: 22rpx;
  line-height: 1.5;
}
