<view class="page">
  <view class="hero-card">
    <view class="hero-top">
      <text class="hero-badge">个人中心</text>
    </view>

    <view class="brand-strip">
      <image class="brand-logo" src="/images/brand-logo.png" mode="aspectFit" />
      <view class="brand-strip-copy">
        <text class="brand-strip-title">味食记菜谱</text>
        <text class="brand-strip-desc">把你的收藏、偏好和做菜记录都留在这里。</text>
      </view>
    </view>

    <view class="profile-main" bindtap="onProfileTap">
      <view class="avatar-shell" catchtap="onAvatarTap">
        <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
      </view>
      <view class="profile-info">
        <text class="profile-name">{{userInfo.nickname}}</text>
        <text class="profile-badge">{{userInfo.level}}</text>
        <text class="profile-location">{{isLoggedIn ? '已连接微信账号' : '登录后同步收藏和资料'}}</text>
      </view>
      <text class="profile-arrow">></text>
    </view>
  </view>

  <view class="section-head">
    <text class="section-title">我的服务</text>
  </view>

  <view class="service-grid">
    <view
      class="service-card"
      wx:for="{{serviceList}}"
      wx:key="key"
      data-url="{{item.url}}"
      data-mode="{{item.mode}}"
      bindtap="onServiceTap"
    >
      <view class="service-icon-wrap">
        <text class="service-icon">{{item.icon}}</text>
      </view>
      <text class="service-title">{{item.title}}</text>
      <text wx:if="{{item.value}}" class="service-value">{{item.value}}</text>
    </view>
  </view>
</view>
