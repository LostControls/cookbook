<view class="page">
  <view class="form-card">
    <view class="field-row">
      <text class="field-label">用户名</text>
      <text class="field-required">*</text>
      <view class="field-input">{{userInfo.nickname}}</view>
    </view>

    <view class="field-row field-row--avatar">
      <text class="field-label">用户头像</text>
      <text class="field-required">*</text>
      <view class="avatar-preview">
        <image class="avatar-image" src="{{userInfo.avatar}}" mode="aspectFill" />
      </view>
    </view>
  </view>

  <button class="submit-btn" bindtap="onSubmit">
    {{isLoggedIn ? '修改' : '去登录'}}
  </button>

  <button wx:if="{{isLoggedIn}}" class="logout-btn" bindtap="onLogout">退出登录</button>
</view>
