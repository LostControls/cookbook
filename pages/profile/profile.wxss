.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(232, 181, 255, 0.18), transparent 26%),
    radial-gradient(circle at top right, rgba(255, 228, 185, 0.24), transparent 24%),
    #fbfbfd;
}

.form-card {
  margin-top: 20rpx;
  padding: 22rpx 26rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 38rpx rgba(15, 23, 42, 0.06);
}

.field-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
}

.field-row--avatar {
  align-items: flex-start;
}

.field-label {
  width: 120rpx;
  font-size: 32rpx;
  color: #181818;
}

.field-required {
  width: 24rpx;
  font-size: 32rpx;
  color: #ff4d4f;
}

.field-input {
  flex: 1;
  min-height: 68rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7ee;
  background: #ffffff;
  line-height: 68rpx;
  font-size: 30rpx;
  color: #23262d;
}

.avatar-preview {
  flex: 1;
  padding-top: 8rpx;
}

.avatar-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f8f3f1;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.12);
}

.submit-btn {
  margin-top: 54rpx;
  border-radius: 999rpx;
  line-height: 88rpx;
  background: #9c84cf;
  color: #ffffff;
  font-size: 34rpx;
}

.submit-btn::after {
  border: none;
}

.logout-btn {
  margin-top: 24rpx;
  border-radius: 999rpx;
  line-height: 84rpx;
  background: #ffffff;
  color: #7c6a9d;
  font-size: 30rpx;
  border: 2rpx solid #e7def7;
}

.logout-btn::after {
  border: none;
}
